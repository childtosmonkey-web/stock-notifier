<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.stocknotifier</string>

    <key>ProgramArguments</key>
    <array>
        <!-- このパスはあなたのMacのユーザー名に合わせて変更してください -->
        <string>/Users/toshihirotsutsumi/projects/stock-notifier/.venv/bin/python3</string>
        <string>/Users/toshihirotsutsumi/projects/stock-notifier/src/main.py</string>
    </array>

    <!-- 毎朝8:00に実行 -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/tmp/stocknotifier.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/stocknotifier-error.log</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
